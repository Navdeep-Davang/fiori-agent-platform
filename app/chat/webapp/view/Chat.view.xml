<mvc:View
    controllerName="acp.chat.controller.Chat"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    class="acpChatShell">
    <Page showHeader="false" backgroundDesign="Solid" class="acpChatPage" enableScrolling="false">
        <content>
            <l:ResponsiveSplitter defaultPane="default">
                <l:PaneContainer orientation="Horizontal">
                    <!-- Session List Panel -->
                    <l:SplitPane requiredParentWidth="250">
                        <l:layoutData>
                            <l:SplitterLayoutData size="250px" resizable="true" />
                        </l:layoutData>
                        <Page title="{i18n>sessionsTitle}" enableScrolling="false" class="acpSessionPage">
                            <headerContent>
                                <Button icon="sap-icon://add" text="{i18n>newSessionBtn}" press=".onNewSession" />
                            </headerContent>
                            <content>
                                <ScrollContainer width="100%"
                                                 vertical="true"
                                                 horizontal="false"
                                                 focusable="true"
                                                 class="acpSessionListScroll">
                                <List id="sessionList"
                                      items="{path: '/ChatSessions', parameters: {$orderby: 'updatedAt desc', $select: 'ID,title,updatedAt,agentId'}, templateShareable: false}"
                                      mode="SingleSelectMaster"
                                          selectionChange=".onSessionSelect"
                                          class="acpSessionList">
                                        <CustomListItem type="Active" class="acpSessionListItem">
                                            <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="acpSessionRow">
                                                <VBox class="acpSessionRowText">
                                                    <layoutData>
                                                        <FlexItemData growFactor="1" shrinkFactor="1" />
                                                    </layoutData>
                                                    <Text text="{title}" wrapping="true" class="acpSessionTitle" />
                                                    <Text text="{path: 'updatedAt', formatter: '.formatSessionDate'}" class="acpSessionMeta" />
                                                </VBox>
                                                <Button icon="sap-icon://delete"
                                                        type="Transparent"
                                                        tooltip="{i18n>deleteSessionTooltip}"
                                                        press=".onDeleteSession"
                                                        class="acpSessionDeleteBtn" />
                                            </HBox>
                                        </CustomListItem>
                                    </List>
                                </ScrollContainer>
                            </content>
                            <footer>
                                <OverflowToolbar design="Transparent">
                                    <Button type="Transparent" icon="sap-icon://log" text="{i18n>logoutBtn}" tooltip="{i18n>logoutBtn}" press=".onLogoutPress" />
                                </OverflowToolbar>
                            </footer>
                        </Page>
                    </l:SplitPane>

                    <!-- Main Chat Panel: one column VBox — Page section is not the scroll shell; only ScrollContainer scrolls -->
                    <l:SplitPane id="default">
                        <Page showHeader="false" showFooter="false" backgroundDesign="Solid" class="acpChatMainPage" enableScrolling="false">
                            <content>
                                <VBox width="100%" alignItems="Stretch" class="acpChatMainColumn">
                                    <Bar design="Header" class="acpChatTopBar">
                                        <contentLeft>
                                            <Title text="{i18n>chatWith}" class="acpChatTitle" />
                                        </contentLeft>
                                        <contentRight>
                                            <HBox alignItems="Center" justifyContent="End" class="acpAgentSelectWrap">
                                                <!-- BusyIndicator placeholder: sap.m.Skeleton is not in OpenUI5 1.120 -->
                                                <HBox alignItems="Center"
                                                      justifyContent="Center"
                                                      visible="{agentsModel>/agentsLoading}"
                                                      width="14rem"
                                                      height="2.5rem"
                                                      class="acpAgentSelectPlaceholder">
                                                    <BusyIndicator size="1.125rem" />
                                                </HBox>
                                                <Select id="agentSelect"
                                                        visible="{= !${agentsModel>/agentsLoading} }"
                                                        items="{path: 'agentsModel>/agents'}"
                                                        change=".onAgentChange"
                                                        width="14rem">
                                                    <core:Item key="{agentsModel>id}" text="{agentsModel>name}" />
                                                </Select>
                                            </HBox>
                                        </contentRight>
                                        <layoutData>
                                            <FlexItemData growFactor="0" shrinkFactor="0" />
                                        </layoutData>
                                    </Bar>
                                    <Panel id="agentPlanPanel"
                                           headerText="{i18n>agentPlanTitle}"
                                           expandable="true"
                                           expanded="{planningModel>/expanded}"
                                           visible="{planningModel>/visible}"
                                           class="acpAgentPlanPanel sapUiSmallMarginBottom">
                                        <content>
                                            <List id="planningList"
                                                  items="{path: 'planningModel>/todos'}"
                                                  showNoData="false"
                                                  class="acpPlanningList">
                                                <StandardListItem title="{planningModel>text}" info="{planningModel>status}" />
                                            </List>
                                        </content>
                                    </Panel>
                                    <ScrollContainer width="100%" vertical="true" horizontal="false" focusable="true"
                                                     class="acpChatScroll acpChatScrollShell">
                                        <layoutData>
                                            <FlexItemData growFactor="1" shrinkFactor="1" baseSize="0" />
                                        </layoutData>
                                        <List id="messageList"
                                              mode="None"
                                              showSeparators="None"
                                              showNoData="false"
                                              class="acpMessageList"
                                              items="{path: 'chatModel>/messages', templateShareable: false}">
                                            <CustomListItem type="Inactive" class="acpMessageListItem">
                                                <FlexBox justifyContent="{chatModel>justifyContent}" width="100%" alignItems="Start"
                                                        class="acpMessageRow sapUiSmallMarginBottom">
                                                    <!-- FlexItemData.styleClass is applied to div.sapMFlexItem around this VBox (see FlexBoxRenderer) — reliable bubble shell -->
                                                    <VBox class="{= 'chatBubbleColumn ' + ${chatModel>bubbleClass} }">
                                                        <layoutData>
                                                            <FlexItemData styleClass="{= ${chatModel>role} === 'user' ? 'acpUserMessageFlexItem' : 'acpAgentMessageFlexItem' }" />
                                                        </layoutData>
                                                        <Text text="{chatModel>content}" wrapping="true" class="chatMessageContent"
                                                              visible="{= ${chatModel>role} === 'user' }" />
                                                        <!-- Streaming: sap.m.Text (binds reliably). Final/history: core:HTML markdown — HTML control replaces DOM each tick and hides typing (OpenUI5 #3459). -->
                                                        <VBox width="100%" visible="{= ${chatModel>role} === 'assistant' }" class="chatMessageHtmlWrap">
                                                            <HBox visible="{= ${chatModel>waitingForFirstToken} === true }"
                                                                  alignItems="Center"
                                                                  class="acpTypingIndicatorHost"
                                                                  accessibleName="{i18n>typingIndicatorAria}">
                                                                <core:HTML preferDOM="false"
                                                                           sanitizeContent="false"
                                                                           content="&lt;div class=&quot;acpTypingIndicator&quot; role=&quot;presentation&quot;&gt;&lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&lt;/div&gt;" />
                                                            </HBox>
                                                            <Text text="{chatModel>streamVisibleText}"
                                                                  wrapping="true"
                                                                  visible="{= ${chatModel>assistantUsePlainText} === true &amp;&amp; !!${chatModel>streamVisibleText} }"
                                                                  class="chatMessageContent chatMessageStreamPlain" />
                                                            <core:HTML content="{chatModel>contentHtml}"
                                                                       preferDOM="false"
                                                                       sanitizeContent="false"
                                                                       visible="{= ${chatModel>assistantUsePlainText} !== true }" />
                                                        </VBox>
                                                        <VBox visible="{= !!${chatModel>toolCalls} &amp;&amp; ${chatModel>toolCalls}.length > 0 }">
                                                            <core:Fragment fragmentName="acp.chat.fragment.ToolTrace" type="XML" />
                                                        </VBox>
                                                    </VBox>
                                                </FlexBox>
                                            </CustomListItem>
                                        </List>
                                    </ScrollContainer>
                                    <!-- Footer: ChatGPT-style single composer card (textarea + toolbar) then credit line -->
                                    <VBox width="100%" class="acpChatFooter" alignItems="Stretch">
                                        <layoutData>
                                            <FlexItemData growFactor="0" shrinkFactor="0" />
                                        </layoutData>
                                        <VBox width="100%" class="acpChatComposer" alignItems="Stretch">
                                            <TextArea id="messageInput" placeholder="{i18n>messagePlaceholder}"
                                                      width="100%"
                                                      rows="2" growing="true" growingMaxLines="10"
                                                      class="acpChatFooter__textarea" />
                                            <HBox width="100%" alignItems="Center" justifyContent="SpaceBetween" class="acpChatFooter__toolbar">
                                                <Button type="Transparent"
                                                        icon="sap-icon://add"
                                                        tooltip="{i18n>composerAttachTooltip}"
                                                        press=".onAttachPress"
                                                        class="acpChatFooter__attach" />
                                                <HBox alignItems="Center" justifyContent="End" class="acpChatFooter__actions">
                                                    <Button id="sendBtn" text="{i18n>sendBtn}" type="Emphasized" press=".onSendMessage" />
                                                    <Button id="stopBtn" text="{i18n>stopBtn}" type="Reject" press=".onStop" visible="false" class="sapUiTinyMarginBegin" />
                                                </HBox>
                                            </HBox>
                                        </VBox>
                                        <Text text="{i18n>footerCredit}" textAlign="Center" width="100%" class="acpChatFooter__description" />
                                    </VBox>
                                </VBox>
                            </content>
                        </Page>
                    </l:SplitPane>
                </l:PaneContainer>
            </l:ResponsiveSplitter>
        </content>
    </Page>
</mvc:View>
