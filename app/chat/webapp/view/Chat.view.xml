<mvc:View
    controllerName="acp.chat.controller.Chat"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">
    <Page showHeader="false" backgroundDesign="List">
        <content>
            <l:ResponsiveSplitter defaultPane="default">
                <l:PaneContainer orientation="Horizontal">
                    <!-- Session List Panel -->
                    <l:SplitPane requiredParentWidth="250">
                        <l:layoutData>
                            <l:SplitterLayoutData size="250px" resizable="true" />
                        </l:layoutData>
                        <Page title="{i18n>sessionsTitle}">
                            <headerContent>
                                <Button icon="sap-icon://add" text="{i18n>newSessionBtn}" press=".onNewSession" />
                            </headerContent>
                            <content>
                                <List id="sessionList" 
                                      items="{path: '/ChatSessions', parameters: {$orderby: 'updatedAt desc'}}"
                                      mode="SingleSelectMaster"
                                      selectionChange=".onSessionSelect">
                                    <StandardListItem
                                        title="{title}"
                                        description="{path: 'updatedAt', type: 'sap.ui.model.type.DateTime', formatOptions: {style: 'short'}}"
                                        type="Active"
                                        press=".onSessionSelect" />
                                </List>
                            </content>
                        </Page>
                    </l:SplitPane>

                    <!-- Main Chat Panel -->
                    <l:SplitPane id="default">
                        <Page backgroundDesign="Solid">
                            <customHeader>
                                <Bar>
                                    <contentLeft>
                                        <Title text="{i18n>chatWith}" />
                                        <Select id="agentSelect" 
                                                items="{path: 'agentsModel>/'}" 
                                                change=".onAgentChange"
                                                width="200px">
                                            <core:Item key="{agentsModel>ID}" text="{agentsModel>name}" />
                                        </Select>
                                    </contentLeft>
                                </Bar>
                            </customHeader>
                            <content>
                                <ScrollContainer height="100%" width="100%" vertical="true" focusable="true">
                                    <VBox id="messageList" class="sapUiSmallMargin" items="{chatModel>/messages}">
                                        <FlexBox justifyContent="{chatModel>justifyContent}" class="sapUiSmallMarginBottom">
                                            <VBox class="{chatModel>bubbleClass}" width="fit-content">
                                                <Text text="{chatModel>content}" class="chatMessageContent" />
                                                <core:Fragment fragmentName="acp.chat.fragment.ToolTrace" type="XML" 
                                                               visible="{= !!${chatModel>toolCalls} &amp;&amp; ${chatModel>toolCalls}.length > 0 }" />
                                            </VBox>
                                        </FlexBox>
                                    </VBox>
                                </ScrollContainer>
                            </content>
                            <footer>
                                <Bar>
                                    <contentMiddle>
                                        <TextArea id="messageInput" placeholder="{i18n>messagePlaceholder}" 
                                                  width="100%" rows="1" growing="true" growingMaxLines="4" 
                                                  liveChange=".onInputLiveChange" />
                                    </contentMiddle>
                                    <contentRight>
                                        <Button id="sendBtn" text="{i18n>sendBtn}" type="Emphasized" press=".onSendMessage" />
                                        <Button id="stopBtn" text="{i18n>stopBtn}" type="Reject" press=".onStop" visible="false" />
                                    </contentRight>
                                </Bar>
                            </footer>
                        </Page>
                    </l:SplitPane>
                </l:PaneContainer>
            </l:ResponsiveSplitter>
        </content>
    </Page>
</mvc:View>
