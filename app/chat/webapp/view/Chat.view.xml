<mvc:View
    controllerName="acp.chat.controller.Chat"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    class="acpChatShell">
    <Page showHeader="false" backgroundDesign="Solid" class="acpChatPage">
        <content>
            <l:ResponsiveSplitter defaultPane="default">
                <l:PaneContainer orientation="Horizontal">
                    <!-- Session List Panel -->
                    <l:SplitPane requiredParentWidth="250">
                        <l:layoutData>
                            <l:SplitterLayoutData size="250px" resizable="true" />
                        </l:layoutData>
                        <Page title="{i18n>sessionsTitle}">
                            <headerContent>
                                <Button icon="sap-icon://add" text="{i18n>newSessionBtn}" press=".onNewSession" />
                            </headerContent>
                            <content>
                                <List id="sessionList" 
                                      items="{path: '/ChatSessions', parameters: {$orderby: 'updatedAt desc'}}"
                                      mode="SingleSelectMaster"
                                      selectionChange=".onSessionSelect">
                                    <StandardListItem
                                        title="{title}"
                                        description="{path: 'updatedAt', formatter: '.formatSessionDate'}"
                                        type="Active"
                                        press=".onSessionSelect" />
                                </List>
                            </content>
                        </Page>
                    </l:SplitPane>

                    <!-- Main Chat Panel -->
                    <l:SplitPane id="default">
                        <Page backgroundDesign="Solid" class="acpChatMainPage">
                            <customHeader>
                                <Bar design="Header">
                                    <contentLeft>
                                        <Title text="{i18n>chatWith}" class="acpChatTitle" />
                                    </contentLeft>
                                    <contentRight>
                                        <Select id="agentSelect"
                                                items="{path: 'agentsModel>/'}"
                                                change=".onAgentChange"
                                                width="14rem">
                                            <core:Item key="{agentsModel>id}" text="{agentsModel>name}" />
                                        </Select>
                                    </contentRight>
                                </Bar>
                            </customHeader>
                            <content>
                                <ScrollContainer height="100%" width="100%" vertical="true" focusable="true" class="acpChatScroll">
                                    <List id="messageList"
                                          mode="None"
                                          showSeparators="None"
                                          showNoData="false"
                                          class="acpMessageList sapUiSmallMargin"
                                          items="{chatModel>/messages}">
                                        <CustomListItem type="Inactive" class="acpMessageListItem">
                                            <FlexBox justifyContent="{chatModel>justifyContent}" width="100%" alignItems="Start" class="sapUiSmallMarginBottom">
                                                <VBox class="{chatModel>bubbleClass} chatBubbleColumn">
                                                    <Text text="{chatModel>content}" class="chatMessageContent" />
                                                    <VBox visible="{= !!${chatModel>toolCalls} &amp;&amp; ${chatModel>toolCalls}.length > 0 }">
                                                        <core:Fragment fragmentName="acp.chat.fragment.ToolTrace" type="XML" />
                                                    </VBox>
                                                </VBox>
                                            </FlexBox>
                                        </CustomListItem>
                                    </List>
                                </ScrollContainer>
                            </content>
                            <footer>
                                <Bar design="Footer" class="acpChatComposerBar">
                                    <contentMiddle>
                                        <TextArea id="messageInput" placeholder="{i18n>messagePlaceholder}"
                                                  width="100%" rows="1" growing="true" growingMaxLines="4"
                                                  class="acpChatInput"
                                                  liveChange=".onInputLiveChange" />
                                    </contentMiddle>
                                    <contentRight>
                                        <Button id="sendBtn" text="{i18n>sendBtn}" type="Emphasized" press=".onSendMessage" class="sapUiTinyMarginBegin" />
                                        <Button id="stopBtn" text="{i18n>stopBtn}" type="Reject" press=".onStop" visible="false" class="sapUiTinyMarginBegin" />
                                    </contentRight>
                                </Bar>
                            </footer>
                        </Page>
                    </l:SplitPane>
                </l:PaneContainer>
            </l:ResponsiveSplitter>
        </content>
    </Page>
</mvc:View>
