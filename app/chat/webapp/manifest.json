{
    "_version": "1.60.0",
    "sap.app": {
        "id": "acp.chat",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "chatService": {
                "uri": "/odata/v4/chat/",
                "type": "OData",
                "settings": {
                    "odataVersion": "4.0",
                    "localUri": "localService/metadata.xml"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "acp.chat.view.App",
            "type": "XML",
            "async": false
        },
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.f": {},
                "sap.ui.layout": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "acp.chat.i18n.i18n"
                }
            },
            "": {
                "dataSource": "chatService",
                "preload": false,
                "settings": {
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": false
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": false,
                "viewPath": "acp.chat.view",
                "controlAggregation": "pages",
                "controlId": "mainApp"
            },
            "routes": [
                {
                    "name": "chat",
                    "pattern": "",
                    "target": [
                        "chat"
                    ]
                }
            ],
            "targets": {
                "chat": {
                    "viewName": "Chat",
                    "viewId": "chat",
                    "viewLevel": 1,
                    "async": false
                }
            }
        }
    }
}
