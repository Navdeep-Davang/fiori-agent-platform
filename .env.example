# =============================================================================
# Local development only — copy to ".env" and fill in values.
# This file is safe to commit. Never commit ".env" (it is git-ignored).
#
# Spectrum 1 (hybrid): CAP + Python run locally; database is SAP HANA Cloud.
# After `cf login` and `cds bind db --to <hana-instance>`, run:
#   npm run deploy:hana
#   npm run watch
#
# On Cloud Foundry, the Python app does not read this file for secrets.
# Set LLM keys there with: cf set-env <app-name> <VAR> <value> && cf restart <app-name>
# =============================================================================

# --- LLM (Python service) ----------------------------------------------------
# One of: anthropic | openai | google-genai
LLM_PROVIDER=google-genai

# Anthropic or OpenAI API key (leave empty if you use GOOGLE_API_KEY only)
LLM_API_KEY=

# Google AI (Gemini) API key — required when LLM_PROVIDER=google-genai
GOOGLE_API_KEY=

# Model id for the chosen provider, e.g.:
#   claude-3-5-sonnet-20241022  /  gpt-4o  /  gemini-3.1-flash-lite-preview
LLM_MODEL=gemini-3.1-flash-lite-preview

# --- CAP hybrid (optional) ----------------------------------------------------
# When true, /api/agents stays empty if AgentGroup CSV data is missing (no dev fallback).
# ACP_STRICT_AGENT_GATING=true

# --- CAP ↔ Python wiring (local) --------------------------------------------
# Base URL of the FastAPI app (CAP calls /chat and /tool-test here)
PYTHON_URL=http://localhost:8000

# Optional: Bearer token for MCP /mcp/tools/call when a tool is elevated (CAP sets elevated + machineToken)
MCP_MACHINE_TOKEN=

# --- SAP HANA Cloud (required for local Python SQL tools) --------------------
# Use the SAME HDI / service-key credentials as CAP after `cds bind`.
# Copy host, port, user (often *_RT), password, and schema from the key JSON.
# On CF, Python uses VCAP_SERVICES instead — these vars are for laptop dev.
HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_SCHEMA=
