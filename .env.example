# =============================================================================
# Local development only — copy to ".env" and fill in values.
# This file is safe to commit. Never commit ".env" (it is git-ignored).
#
# Spectrum 1 (hybrid): CAP + Python run locally; database is SAP HANA Cloud.
# After `cf login` and `cds bind db --to <hana-instance>`, run:
#   npm run deploy:hana
#   npm run watch
#
# On Cloud Foundry, the Python app does not read this file for secrets.
# Set LLM keys there with: cf set-env <app-name> <VAR> <value> && cf restart <app-name>
# =============================================================================

# --- LLM (Python service) ----------------------------------------------------
# One of: anthropic | openai | google-genai
LLM_PROVIDER=google-genai

# Anthropic or OpenAI API key (leave empty if you use GOOGLE_API_KEY only)
LLM_API_KEY=

# Google AI (Gemini) API key — required when LLM_PROVIDER=google-genai
GOOGLE_API_KEY=

# Model id for the chosen provider, e.g.:
#   claude-3-5-sonnet-20241022  /  gpt-4o  /  gemini-3.1-flash-lite-preview
LLM_MODEL=gemini-3.1-flash-lite-preview

# --- CAP (optional) -----------------------------------------------------------
# Log the XSUAA access JWT to the CAP process terminal after each /api request (dev only; never in production).
# ACP_LOG_JWT=true

# --- CAP ↔ Python wiring (local) --------------------------------------------
# Base URL of the FastAPI app (CAP calls /chat and /tool-test here)
PYTHON_URL=http://localhost:8000

# Shared secret on the CAP → Python hop (CAP sends X-Internal-Token; Python rejects if mismatch when set).
# Generate a long random string; keep out of git (set in .env locally, cf set-env in CF).
ACP_INTERNAL_TOKEN=

# Optional: Bearer token for MCP /mcp/tools/call when a tool is elevated (CAP sets elevated + machineToken)
MCP_MACHINE_TOKEN=

# --- Phase 9 — summarization (Python) -----------------------------------------
# Rough token threshold (len/4) before inline session summarization runs
SUMMARY_TOKEN_THRESHOLD=6000

# --- Phase 6b — Langfuse (optional; never commit secrets) ---------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- SAP HANA Cloud (required for local Python SQL tools) --------------------
# Use the SAME HDI / service-key credentials as CAP after `cds bind`.
# Copy host, port, user (often *_RT), password, and schema from the key JSON.
# On CF, Python uses VCAP_SERVICES instead — these vars are for laptop dev.
HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_SCHEMA=

# --- BTP Authorization API (optional — separate XSUAA instance plan `apiaccess`) -----------------
# From service key of the apiaccess instance: clientid, clientsecret, apiurl, uaa.url
# Token URL must be the OAuth2 endpoint, e.g. https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
# BTP_AUTH_API_CLIENT_ID=
# BTP_AUTH_API_CLIENT_SECRET=
# BTP_AUTH_API_TOKEN_URL=
# BTP_AUTH_API_BASE_URL=
# Optional: BTP_AUTH_API_UAA_URL=
# Optional: append &resource= to token POST if the token endpoint returns invalid_grant without it
# BTP_AUTH_API_TOKEN_RESOURCE=

# --- IAS scripting (optional — scripts/ias-scim.ps1) ---------------------------
# IAS_CLIENT_ID=
# IAS_CLIENT_SECRET=
# IAS_TOKEN_URL=https://<tenant>.trial-accounts.ondemand.com/oauth2/token
# IAS_SCIM_BASE=https://<tenant>.trial-accounts.ondemand.com/service/scim
# Optional: IAS_TOKEN_RESOURCE= (tenant base URL for &resource= on token POST)
# OIDC discovery: -Action OpenIdMetadata (needs IAS_TOKEN_URL)
# Decoded user JWT claims (ROPC, if enabled): IAS_ROPC_USER= IAS_ROPC_PASSWORD= — optional IAS_OIDC_SCOPE=openid profile email
