{
  "welcomeFile": "/chat/webapp/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/chat/webapp/index.html"
  },
  "routes": [
    {
      "source": "^/admin/(.*)",
      "target": "/admin/$1",
      "destination": "cap",
      "csrfProtection": true
    },
    {
      "source": "^/chat(\\?.*)?$",
      "target": "/chat/webapp/index.html$1",
      "destination": "cap",
      "csrfProtection": true
    },
    {
      "source": "^/chat/(.*)",
      "target": "/chat/$1",
      "destination": "cap",
      "csrfProtection": true
    },
    {
      "source": "^/api/(.*)",
      "target": "/api/$1",
      "destination": "cap",
      "csrfProtection": false
    },
    {
      "source": "^/odata/(.*)",
      "target": "/odata/$1",
      "destination": "cap",
      "csrfProtection": false
    }
  ]
}
