{
  "name": "agent-control-plane",
  "version": "1.0.0",
  "private": true,
  "description": "Fiori Agent Platform — CAP, UI5, Python executor",
  "workspaces": [
    "app/admin",
    "app/chat",
    "approuter"
  ],
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap/cds": "^8",
    "@sap/hana-client": "^2",
    "@sap/xssec": "^4",
    "axios": "^1.7.7",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@sap/eslint-plugin-cds": "^3",
    "rimraf": "^5.0.10"
  },
  "scripts": {
    "watch": "cds watch --profile hybrid",
    "deploy:hana": "cds deploy --profile hybrid",
    "build:cap": "cds build --production",
    "start": "cds run --profile hybrid",
    "lint": "eslint .",
    "start:approuter": "cds bind --exec -- npm run start --prefix approuter"
  },
  "cds": {
    "requires": {
      "db": {
        "[hybrid]": {
          "kind": "hana"
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[hybrid]": {
          "kind": "xsuaa"
        },
        "[development]": {
          "kind": "xsuaa"
        },
        "[production]": {
          "kind": "xsuaa"
        }
      }
    }
  }
}
